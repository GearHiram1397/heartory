# Copy to .env and fill in values from your Supabase project settings.
# EXPO_PUBLIC_* vars are inlined into the client bundle — only put values here
# that are safe to be public. Server secrets (service_role, Stripe secret key,
# webhook signing secret) live in Supabase Edge Function secrets, never here.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
