# Heartory environment configuration
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time.
# The Supabase anon/publishable key is designed to be public — it is safe in
# the client because Row-Level Security enforces all data access on the server.
# NEVER put the Supabase service_role key or any Stripe SECRET key in an
# EXPO_PUBLIC_ var — those belong only in server-side Edge Function secrets.

EXPO_PUBLIC_SUPABASE_URL=https://ictlxbtbomiehbenvpfv.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_RfzzHk0Vrcvr8XRtnKKGqA_-6l25Bv9
